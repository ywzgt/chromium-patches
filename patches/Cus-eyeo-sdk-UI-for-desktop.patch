+const CONFIG = "default";
+
+export const AdblockAPI = {
+  async isEnabled() {
+    return chrome.eyeoFilteringPrivate.isEnabled(CONFIG);
+  },
+
+  async setEnabled(enabled: boolean) {
+    return chrome.eyeoFilteringPrivate.setEnabled(CONFIG, enabled);
+  },
+
+  async getFilters() {
+    return chrome.eyeoFilteringPrivate.getCustomFilters(CONFIG);
+  },
+
+  async addFilter(filter: string) {
+    return chrome.eyeoFilteringPrivate.addCustomFilter(CONFIG, filter);
+  },
+
+  async removeFilter(filter: string) {
+    return chrome.eyeoFilteringPrivate.removeCustomFilter(CONFIG, filter);
+  },
+
+  async getDomains() {
+    return chrome.eyeoFilteringPrivate.getAllowedDomains(CONFIG);
+  },
+
+  async addDomain(domain: string) {
+    return chrome.eyeoFilteringPrivate.addAllowedDomain(CONFIG, domain);
+  },
+
+  async removeDomain(domain: string) {
+    return chrome.eyeoFilteringPrivate.removeAllowedDomain(CONFIG, domain);
+  },
+
+  async getLists() {
+    return chrome.eyeoFilteringPrivate.getFilterLists(CONFIG);
+  },
+
+  async addList(url: string) {
+    return chrome.eyeoFilteringPrivate.addFilterList(CONFIG, url);
+  },
+
+  async removeList(url: string) {
+    return chrome.eyeoFilteringPrivate.removeFilterList(CONFIG, url);
+  }
+};
