+import {AdblockAPI} from "./api.js";
+
+async function init() {
+  await loadAll();
+
+  document.getElementById("enabledToggle")!
+    .addEventListener("change", async (e: any) => {
+      await AdblockAPI.setEnabled(e.target.checked);
+    });
+
+  document.getElementById("addFilter")!
+    .addEventListener("click", async () => {
+      const input = (document.getElementById("filterInput") as any).value;
+      await AdblockAPI.addFilter(input);
+    });
+
+  document.getElementById("addDomain")!
+    .addEventListener("click", async () => {
+      const input = (document.getElementById("domainInput") as any).value;
+      await AdblockAPI.addDomain(input);
+    });
+
+  document.getElementById("addList")!
+    .addEventListener("click", async () => {
+      const input = (document.getElementById("listInput") as any).value;
+      await AdblockAPI.addList(input);
+    });
+
+  bindEvents();
+}
+
+async function loadAll() {
+  (document.getElementById("enabledToggle") as any).checked =
+    await AdblockAPI.isEnabled();
+
+  renderList("lists", await AdblockAPI.getLists(), "url", AdblockAPI.removeList);
+  renderList("filters", await AdblockAPI.getFilters(), null, AdblockAPI.removeFilter);
+  renderList("domains", await AdblockAPI.getDomains(), null, AdblockAPI.removeDomain);
+}
+
+function renderList(id: string, items: any[], key: string | null, removeFn: any) {
+  const el = document.getElementById(id)!;
+  el.innerHTML = "";
+
+  items.forEach(item => {
+    const value = key ? item[key] : item;
+
+    const div = document.createElement("div");
+    div.className = "item";
+
+    div.innerHTML = `
+      <span>${value}</span>
+      <button data-id="${value}">Remove</button>
+    `;
+
+    div.querySelector("button")!.onclick = () => removeFn(value);
+
+    el.appendChild(div);
+  });
+}
+
+// 🔥 事件驱动
+function bindEvents() {
+  chrome.runtime.onMessage.addListener(msg => {
+    if (msg.event === "listsChanged" ||
+        msg.event === "filtersChanged" ||
+        msg.event === "domainsChanged") {
+      loadAll();
+    }
+  });
+}
+
+init();
